# ─── LLM (at least one required, priority: Anthropic > DashScope > OpenAI) ───
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DASHSCOPE_API_KEY=sk-...              # Alibaba Cloud / Qwen via DashScope

# ─── Model overrides (optional) ──────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6
DASHSCOPE_MODEL=qwen-plus             # qwen-turbo | qwen-plus | qwen-max | qwen-long

# ─── Tools ───────────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=BSA...          # omit to use mock search results

# ─── Tuning ──────────────────────────────────────────────────────────────────
SEARCH_TIMEOUT_MS=8000
SEARCH_MAX_RESULTS=5
FETCH_TIMEOUT_MS=10000
FETCH_MAX_CONTENT_LEN=6000
MAX_URLS_TO_FETCH=3

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info                       # debug | info | warn | error
LOG_FORMAT=json                      # json | pretty
